<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Back button row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_btn_outline"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:text="← Back"
            android:contentDescription="Go back"
            android:textColor="@color/gold"
            android:textSize="13sp" />

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="New Recording"
        android:textColor="@color/text_primary"
        android:textSize="26sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/tap_to_record"
        android:textColor="@color/text_primary_70"
        android:textSize="14sp" />

    <!-- Timer -->
    <TextView
        android:id="@+id/tvTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="0:00"
        android:textColor="@color/gold"
        android:textSize="48sp"
        android:textStyle="bold" />

    <!-- Waveform bars -->
    <LinearLayout
        android:id="@+id/layoutWaveform"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp">

        <View android:id="@+id/bar1"  android:layout_width="8dp" android:layout_height="10dp" android:layout_marginHorizontal="3dp" android:background="@drawable/bg_gold_round" />
        <View android:id="@+id/bar2"  android:layout_width="8dp" android:layout_height="10dp" android:layout_marginHorizontal="3dp" android:background="@drawable/bg_gold_round" />
        <View android:id="@+id/bar3"  android:layout_width="8dp" android:layout_height="10dp" android:layout_marginHorizontal="3dp" android:background="@drawable/bg_gold_round" />
        <View android:id="@+id/bar4"  android:layout_width="8dp" android:layout_height="10dp" android:layout_marginHorizontal="3dp" android:background="@drawable/bg_gold_round" />
        <View android:id="@+id/bar5"  android:layout_width="8dp" android:layout_height="10dp" android:layout_marginHorizontal="3dp" android:background="@drawable/bg_gold_round" />
        <View android:id="@+id/bar6"  android:layout_width="8dp" android:layout_height="10dp" android:layout_marginHorizontal="3dp" android:background="@drawable/bg_gold_round" />
        <View android:id="@+id/bar7"  android:layout_width="8dp" android:layout_height="10dp" android:layout_marginHorizontal="3dp" android:background="@drawable/bg_gold_round" />
        <View android:id="@+id/bar8"  android:layout_width="8dp" android:layout_height="10dp" android:layout_marginHorizontal="3dp" android:background="@drawable/bg_gold_round" />
        <View android:id="@+id/bar9"  android:layout_width="8dp" android:layout_height="10dp" android:layout_marginHorizontal="3dp" android:background="@drawable/bg_gold_round" />
        <View android:id="@+id/bar10" android:layout_width="8dp" android:layout_height="10dp" android:layout_marginHorizontal="3dp" android:background="@drawable/bg_gold_round" />
        <View android:id="@+id/bar11" android:layout_width="8dp" android:layout_height="10dp" android:layout_marginHorizontal="3dp" android:background="@drawable/bg_gold_round" />
        <View android:id="@+id/bar12" android:layout_width="8dp" android:layout_height="10dp" android:layout_marginHorizontal="3dp" android:background="@drawable/bg_gold_round" />

    </LinearLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:layout_marginTop="32dp"
        android:gravity="center">

        <View
            android:id="@+id/pulse2"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_centerInParent="true"
            android:background="@drawable/bg_gold_round"
            android:alpha="0" />

        <View
            android:id="@+id/pulse1"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_centerInParent="true"
            android:background="@drawable/bg_gold_round"
            android:alpha="0" />

        <LinearLayout
            android:id="@+id/btnMic"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_centerInParent="true"
            android:background="@drawable/bg_gold_round"
            android:elevation="8dp"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@android:drawable/ic_btn_speak_now"
                android:contentDescription="Microphone recording button"
                android:tint="@color/bg_primary" />

        </LinearLayout>

    </RelativeLayout>

    <TextView
        android:id="@+id/tvRecordLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/start_recording"
        android:textColor="@color/text_primary_70"
        android:textSize="14sp" />

</LinearLayout>
